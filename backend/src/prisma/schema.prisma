// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(MECHANIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  serviceOrders ServiceOrder[]
  budgets       Budget[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  phone     String
  cpf       String?  @unique
  password  String
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  budgets       Budget[]
}

model Vehicle {
  id           Int      @id @default(autoincrement())
  plate        String   @unique
  brand        String
  model        String
  year         Int
  color        String?
  mileage      Int?
  observations String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  serviceOrders ServiceOrder[]
  budgets       Budget[]
  visits        VehicleVisit[]
}

model VehicleVisit {
  id          Int      @id @default(autoincrement())
  visitDate   DateTime @default(now())
  mileage     Int?
  reason      String?
  observations String?
  createdAt   DateTime @default(now())

  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}

model ServiceOrder {
  id             Int           @id @default(autoincrement())
  orderNumber    String        @unique
  status         OrderStatus   @default(PENDING)
  entryDate      DateTime      @default(now())
  completionDate DateTime?
  totalValue     Decimal?      @db.Decimal(10, 2)
  observations   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  clientId  Int
  client    Client  @relation(fields: [clientId], references: [id])
  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  userId    Int
  user      User    @relation(fields: [userId], references: [id])

  services ServiceItem[]
  parts    PartItem[]
}

model Budget {
  id          Int          @id @default(autoincrement())
  budgetNumber String      @unique
  status      BudgetStatus @default(PENDING)
  validUntil  DateTime?
  totalValue  Decimal?     @db.Decimal(10, 2)
  observations String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  clientId  Int
  client    Client  @relation(fields: [clientId], references: [id])
  vehicleId Int
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  userId    Int
  user      User    @relation(fields: [userId], references: [id])

  services ServiceItem[]
  parts    PartItem[]
}

model ServiceItem {
  id          Int     @id @default(autoincrement())
  description String
  unitValue   Decimal @db.Decimal(10, 2)
  quantity    Int     @default(1)
  totalValue  Decimal @db.Decimal(10, 2)

  serviceOrderId Int?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  budgetId       Int?
  budget         Budget?       @relation(fields: [budgetId], references: [id])
}

model PartItem {
  id              Int      @id @default(autoincrement())
  name            String
  partNumber      String?
  quantity        Int      @default(1)
  unitValue       Decimal  @db.Decimal(10, 2)
  totalValue      Decimal  @db.Decimal(10, 2)
  warrantyMonths  Int?     @default(0)
  warrantyExpires DateTime?

  serviceOrderId Int?
  serviceOrder   ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  budgetId       Int?
  budget         Budget?       @relation(fields: [budgetId], references: [id])
}

enum Role {
  ADMIN
  MECHANIC
}

enum Status {
  ACTIVE
  INACTIVE
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BudgetStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}
